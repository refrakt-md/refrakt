{
  "name": "@refrakt-md/lumina",
  "description": "Lumina theme for refrakt.md — design tokens, CSS, identity transform, and layout configs",
  "version": "0.10.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refrakt-md/refrakt.git",
    "directory": "packages/lumina"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/transform.js",
  "types": "dist/transform.d.ts",
  "exports": {
    ".": "./index.css",
    "./base.css": "./base.css",
    "./transform": {
      "types": "./dist/transform.d.ts",
      "default": "./dist/transform.js"
    },
    "./manifest": "./manifest.json",
    "./contracts": "./contracts/structures.json",
    "./layouts": {
      "types": "./dist/layouts.d.ts",
      "default": "./dist/layouts.js"
    },
    "./styles/runes/*.css": "./styles/runes/*.css"
  },
  "files": [
    "dist",
    "base.css",
    "index.css",
    "tokens",
    "styles",
    "contracts",
    "manifest.json",
    "layouts",
    "svelte"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@refrakt-md/runes": "0.10.0",
    "@refrakt-md/transform": "0.10.0",
    "@refrakt-md/types": "0.10.0"
  },
  "devDependencies": {
    "postcss": "^8.4.0"
  }
}
