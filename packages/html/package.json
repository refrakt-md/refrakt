{
  "name": "@refrakt-md/html",
  "description": "Pure HTML renderer for refrakt.md content — no framework required",
  "version": "0.11.2",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refrakt-md/refrakt.git",
    "directory": "packages/html"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@refrakt-md/behaviors": "0.11.2",
    "@refrakt-md/transform": "0.11.2",
    "@refrakt-md/types": "0.11.2"
  }
}
