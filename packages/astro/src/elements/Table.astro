---
/**
 * Table element override — wraps <table> in a scrollable container.
 */
import type { SerializedTag } from '@refrakt-md/types';

interface Props {
	tag: SerializedTag;
}

const { tag } = Astro.props;

// Filter attributes for HTML output
const attrs = Object.entries(tag.attributes)
	.filter(([k, v]) => k !== '$$mdtype' && v !== undefined && v !== null && v !== false)
	.map(([k, v]) => `${k}="${String(v === true ? '' : v).replace(/"/g, '&quot;')}"`)
	.join(' ');
---

<div class="rf-table-wrapper">
	<table {...tag.attributes}>
		<slot />
	</table>
</div>
