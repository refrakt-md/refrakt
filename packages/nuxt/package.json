{
  "name": "@refrakt-md/nuxt",
  "description": "Nuxt module for refrakt.md — render Markdoc runes in Nuxt projects",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refrakt-md/refrakt.git",
    "directory": "packages/nuxt"
  },
  "bugs": "https://github.com/refrakt-md/refrakt/issues",
  "homepage": "https://github.com/refrakt-md/refrakt",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@refrakt-md/behaviors": "1.0.0",
    "@refrakt-md/content": "1.0.0",
    "@refrakt-md/transform": "1.0.0",
    "@refrakt-md/types": "1.0.0"
  },
  "devDependencies": {
    "nuxt": "^3.0.0",
    "vue": "^3.0.0"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0"
  }
}
