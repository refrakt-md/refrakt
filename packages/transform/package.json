{
  "name": "@refrakt-md/transform",
  "description": "Identity transform engine for refrakt.md themes — BEM classes, structural injection, meta consumption",
  "version": "0.25.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refrakt-md/refrakt.git",
    "directory": "packages/transform"
  },
  "bugs": "https://github.com/refrakt-md/refrakt/issues",
  "homepage": "https://github.com/refrakt-md/refrakt",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/adapter-node.d.ts",
      "default": "./dist/adapter-node.js"
    },
    "./refrakt.config.schema.json": "./refrakt.config.schema.json",
    "./theme-tokens.schema.json": "./theme-tokens.schema.json"
  },
  "files": [
    "dist",
    "refrakt.config.schema.json",
    "theme-tokens.schema.json"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@markdoc/markdoc": "0.4.0",
    "@refrakt-md/types": "0.25.1"
  },
  "devDependencies": {
    "ajv": "^8.17.0"
  }
}
