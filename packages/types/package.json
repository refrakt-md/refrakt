{
  "name": "@refrakt-md/types",
  "description": "Shared type definitions for refrakt.md",
  "version": "0.26.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refrakt-md/refrakt.git",
    "directory": "packages/types"
  },
  "bugs": "https://github.com/refrakt-md/refrakt/issues",
  "homepage": "https://github.com/refrakt-md/refrakt",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./project-files": {
      "types": "./dist/project-files.d.ts",
      "default": "./dist/project-files.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@types/json-schema": "^7.0.15"
  }
